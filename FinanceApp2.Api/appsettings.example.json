{
  "ConnectionStrings": {
    "LoggingDb": "YOUR_CONNECTION_STRING_HERE",
    "DefaultConnection": "YOUR_CONNECTION_STRING_HERE"
  },
  "RemoteLogging": {
    "ApplicationName": "FinanceApp2.Api",
    "Endpoint": "YOUR_LOGGING_ENDPOINT_HERE"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Client": {
    "Host": "YOUR_CLIENT_HOST_HERE"
  },
  "Jwt": {
    "Key": "YOUR_JWT_KEY_HERE",
    "Issuer": "YOUR_JWT_ISSUER_HERE",
    "Audience": "YOUR_JWT_AUDIENCE_HERE",
    "ExpireMinutes": 43200
  },
  "Smtp": {
    "Host": "YOUR_SMTP_HOST_HERE",
    "Port": 587,
    "EnableSsl": true,
    "Username": "YOUR_SMTP_USERNAME_HERE",
    "Password": "YOUR_SMTP_PASSWORD_HERE",
    "FromEmail": "YOUR_SMTP_FROM_EMAIL_HERE",
    "FromName": "YOUR_SMTP_FROM_NAME_HERE"
  },
  "AllowedHosts": "*"
}
